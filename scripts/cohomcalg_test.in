# cohomCalg input for CY₃(36,98) ambient toric variety
# Generated from GLSM charge data
#
# The fan has 37 rays, 32 from GLSM + 5 extra (indices 32-36 in κ data)
# Ambient Picard rank = 32, h¹¹(CY) = 36
#
# Format: vertex name = (coordinates) | PIC: class | GLSM: (charges);
# Using a simplified approach: compute ambient cohomology for key divisors

# Vertex 0: coordinate origin
vertex v0 = ( 1, 0, 0, 0 ) | PIC: D0 | GLSM: ( 0 );
vertex v1 = ( -15, -10, -4, 0 ) | PIC: D1 | GLSM: ( 4 );
vertex v2 = ( 0, 0, 1, 0 ) | PIC: D2 | GLSM: ( 12 );
vertex v3 = ( 1, 2, 0, 0 ) | PIC: D3 | GLSM: ( 2 );
vertex v4 = ( -47, -30, -12, -4 ) | PIC: D4 | GLSM: ( 10 );
vertex v5 = ( 0, 0, 0, 1 ) | PIC: D5 | GLSM: ( 9 );
srideal [v0*v1*v2*v3*v4*v5];

# Ambient cohomology of O(D2) — the divisor with charge 12 (Higgs-like)
ambientcohom O( 0, 0, 1, 0, 0, 0 );

# Ambient cohomology of O(D4) — the Top divisor (charge 10)
ambientcohom O( 0, 0, 0, 0, 1, 0 );

# Ambient cohomology of O(D6) — the divisor along charge 8 direction
ambientcohom O( 0, 0, 0, 0, 0, 0 );

# Ambient cohomology of O(D7) — lepton sector divisor (charge 6)
ambientcohom O( 0, 0, 0, 0, 0, -1 );

# Ambient cohomology of O(D₂+D₄) — sum of two important divisors
ambientcohom O( 0, 0, 1, 0, 1, 0 );

# Ambient cohomology of anti-canonical O(-K_X) = O(sum vertices)
ambientcohom O( -1, -1, -1, -1, -1, -1 );
